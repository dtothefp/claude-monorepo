# Claude Monorepo, environment template
#
# Copy this to .env and fill in only the keys you actually use. Everything is
# optional. The pipeline runs on free, local tooling out of the box and reaches
# for these APIs only when a specific skill or agent needs one.
#
# NEVER commit your real .env. It is gitignored.

# --- Discovery / scraping ---
# Apify powers social + Instagram scraping (social-ingest, ig-research, intelligence-agent).
# Free tier available, no card. https://apify.com
APIFY_API_KEY=

# Google Gemini, used for video analysis in the discovery agents.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Image / media skills (only if you add media skills) ---
# OpenAI, for image generation/editing skills.
OPENAI_API_KEY=

# --- Notes ---
# Gmail, Notion, Slack, and Linear are reached through MCP connectors configured
# in your agent, not through keys here. See the Tool Routing section in AGENTS.md.
